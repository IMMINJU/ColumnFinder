<UserControl x:Class="ColumnFinder.Views.PreviewPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White" BorderBrush="#E5E5E5" BorderThickness="0,0,1,0">
        <Grid Margin="20,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 큰 미리보기 영역 -->
            <Grid Grid.Row="0">
                <Image x:Name="Thumb" Stretch="Uniform" StretchDirection="DownOnly"/>
                <Image x:Name="BigIcon" Width="128" Height="128"
                       Visibility="Collapsed"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <ScrollViewer x:Name="TextScroll"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Background="#FAFAFA"
                              BorderBrush="#E5E5E5" BorderThickness="1">
                    <TextBlock x:Name="TextPreview"
                               FontFamily="Cascadia Mono, Consolas"
                               FontSize="11"
                               Padding="10"
                               TextWrapping="NoWrap"/>
                </ScrollViewer>
            </Grid>

            <!-- 파일명 -->
            <TextBlock Grid.Row="1" x:Name="NameText"
                       FontSize="15" FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,16,0,8"/>

            <!-- 메타 정보 -->
            <StackPanel Grid.Row="2" x:Name="MetaPanel" HorizontalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>
