<UserControl x:Class="ColumnFinder.Views.MillerColumn"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="120">
    <Border BorderBrush="#E5E5E5" BorderThickness="0,0,1,0" Background="White">
        <ListBox x:Name="List"
                 BorderThickness="0"
                 Background="White"
                 SelectionMode="Extended"
                 SelectionChanged="List_SelectionChanged"
                 MouseDoubleClick="List_MouseDoubleClick"
                 KeyDown="List_KeyDown"
                 AllowDrop="True"
                 Drop="List_Drop"
                 DragOver="List_DragOver"
                 PreviewMouseLeftButtonDown="List_PreviewMouseLeftButtonDown"
                 PreviewMouseMove="List_PreviewMouseMove"
                 MouseRightButtonUp="List_MouseRightButtonUp"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="열기" Click="Ctx_Open_Click"/>
                    <Separator/>
                    <MenuItem Header="잘라내기" Click="Ctx_Cut_Click" InputGestureText="Ctrl+X"/>
                    <MenuItem Header="복사" Click="Ctx_Copy_Click" InputGestureText="Ctrl+C"/>
                    <MenuItem Header="붙여넣기" Click="Ctx_Paste_Click" InputGestureText="Ctrl+V"/>
                    <Separator/>
                    <MenuItem Header="이름 바꾸기" Click="Ctx_Rename_Click" InputGestureText="F2"/>
                    <MenuItem Header="삭제" Click="Ctx_Delete_Click" InputGestureText="Del"/>
                    <Separator/>
                    <MenuItem Header="탐색기에서 보기" Click="Ctx_OpenInExplorer_Click"/>
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2,3">
                        <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Border>
</UserControl>
